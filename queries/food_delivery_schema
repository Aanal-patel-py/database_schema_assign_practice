-- Database: food_delivery_system

CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    phone_number CHAR(10) NOT NULL UNIQUE CHECK (phone_number ~ '^[0-9]{10}$'),
    email VARCHAR(120) UNIQUE,
    address VARCHAR,
    city VARCHAR(100),
    state VARCHAR(100)
);

CREATE TABLE restaurants (
    id SERIAL PRIMARY KEY,
    name VARCHAR(150) NOT NULL,
    phone_number CHAR(10) NOT NULL UNIQUE CHECK (phone_number ~ '^[0-9]{10}$'),
    email VARCHAR(120) UNIQUE,
    address VARCHAR,
    city VARCHAR(100),
    state VARCHAR(100),
    type_of_restro VARCHAR(100) NOT NULL
);

CREATE TABLE menu_items (
    id SERIAL PRIMARY KEY,
    r_id INT NOT NULL REFERENCES restaurants(id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL,
    unit_price DECIMAL(10,2) NOT NULL CHECK (unit_price >= 0),
    description TEXT not null
);


CREATE TYPE vehicle_type_enum AS ENUM 
('car','bike','activa');
CREATE TABLE delivery_agents (
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    city VARCHAR(100),
    address VARCHAR(255),
    phone_number CHAR(10) NOT NULL UNIQUE CHECK (phone_number ~ '^[0-9]{10}$'),
    email VARCHAR(120) UNIQUE,
    vehicle_type vehicle_type_enum NOT NULL,
    vehicle_number VARCHAR(50) NOT NULL
);

CREATE TYPE order_status_enum AS ENUM 
('preparing','on_the_way','delivered','cancelled');
CREATE TABLE orders (
    id SERIAL PRIMARY KEY,
    u_id INT NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    r_id INT NOT NULL REFERENCES restaurants(id) ON DELETE RESTRICT,
    agent_id INT NOT NULL REFERENCES delivery_agents(id) ON DELETE SET NULL,
    status order_status_enum NOT NULL DEFAULT 'preparing',
    price DECIMAL(10,2) NOT NULL CHECK (price >= 0),
    order_date DATE NOT NULL,
    order_time TIME NOT NULL
);

CREATE TABLE order_items (
    id SERIAL PRIMARY KEY,
    order_id INT NOT NULL REFERENCES orders(id) ON DELETE CASCADE,
    menu_item_id INT NOT NULL REFERENCES menu_items(id) ON DELETE RESTRICT,
    quantity INT NOT NULL CHECK (quantity > 0),
    total_price DECIMAL(10,2) NOT NULL CHECK (total_price >= 0)
);

CREATE TABLE ratings (
    id SERIAL PRIMARY KEY,
    order_id INT NOT NULL UNIQUE REFERENCES orders(id) ON DELETE CASCADE,
    rating INT NOT NULL CHECK (rating BETWEEN 1 AND 5),
    reviews TEXT
);

CREATE INDEX idx_orders_user_id ON orders (u_id);

CREATE INDEX idx_orders_restaurant_id ON orders (r_id);

CREATE INDEX idx_orders_agent_id ON orders (agent_id);
CREATE INDEX idx_menu_items_restaurant_id ON menu_items (r_id);